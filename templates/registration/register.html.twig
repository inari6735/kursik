{% extends 'base_auth.html.twig' %}

{% block title %}Register — kursik{% endblock %}

{% block body %}
    <twig:AuthCard title="Register">
        {{ form_start(form) }}
            {{ form_row(form.email) }}
            {{ form_row(form.plainPassword.first) }}
            {{ form_row(form.plainPassword.second) }}
            <twig:Button fullWidth>Create account</twig:Button>
        {{ form_end(form) }}

        <twig:block name="footer">
            Already have an account? <twig:Link href="{{ path('app_login') }}">Log in</twig:Link>
        </twig:block>
    </twig:AuthCard>
{% endblock %}
