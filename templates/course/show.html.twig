{% extends 'base.html.twig' %}

{% block title %}{{ course.title }} — kursik{% endblock %}

{% block main %}
    <twig:ContentColumn>
        <twig:PageHeader title="{{ course.title }}">
            <twig:block name="actions">
                {% if course.status == 'draft' %}
                    {% if is_granted('course.rename') %}
                        <twig:Button variant="ghost" href="{{ path('course_rename', {id: course.id}) }}">Edit</twig:Button>
                    {% endif %}
                    {% if is_granted('course.publish') %}
                        <form action="{{ path('course_publish', {id: course.id}) }}" method="post">
                            <input type="hidden" name="_token" value="{{ csrf_token('publish-course-' ~ course.id) }}">
                            <twig:Button>Publish</twig:Button>
                        </form>
                    {% endif %}
                {% endif %}
            </twig:block>
        </twig:PageHeader>

        {% if course.content %}
            <twig:Course:Content :blocks="course.content" />
        {% else %}
            <twig:Muted>This course has no content yet.</twig:Muted>
        {% endif %}
    </twig:ContentColumn>
{% endblock %}
