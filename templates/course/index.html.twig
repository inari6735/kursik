{% extends 'base.html.twig' %}

{% block title %}Courses — kursik{% endblock %}

{% block body %}
    <twig:PageHeader title="Courses">
        <twig:block name="actions">
            {% if is_granted('course.create') %}
                <twig:Button href="{{ path('course_new') }}">New course</twig:Button>
            {% endif %}
        </twig:block>
    </twig:PageHeader>

    {% if courses is empty %}
        <twig:EmptyState title="No courses yet" message="Create your first course to get started.">
            {% if is_granted('course.create') %}
                <twig:Button href="{{ path('course_new') }}">Create a course</twig:Button>
            {% endif %}
        </twig:EmptyState>
    {% else %}
        <twig:CardGrid>
            {% for course in courses %}
                <twig:Course:Card :course="course" />
            {% endfor %}
        </twig:CardGrid>
    {% endif %}
{% endblock %}
