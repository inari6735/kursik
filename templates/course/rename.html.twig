{% extends 'base.html.twig' %}

{% block title %}Edit {{ course.title }} — kursik{% endblock %}

{% block body %}
    <twig:PageHeader title="Edit «{{ course.title }}»" />

    <twig:Card>
        {{ form_start(form) }}
            {{ form_row(form.title) }}
            {{ form_row(form.description) }}

            <twig:EditorField label="Content" uploadUrl="{{ path('course_image_upload') }}" attachUrl="{{ path('course_file_upload') }}">
                {{ form_widget(form.content, {attr: {'data-editor-target': 'input'}}) }}
            </twig:EditorField>

            <twig:FormActions>
                <twig:Button>Save changes</twig:Button>
                <twig:Button variant="ghost" href="{{ path('course_show', {id: course.id}) }}">Cancel</twig:Button>
            </twig:FormActions>
        {{ form_end(form) }}
    </twig:Card>
{% endblock %}
