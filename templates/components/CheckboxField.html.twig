{% props label, name, value, checked = false, description = null %}

<label class="mb-2 flex cursor-pointer items-start gap-3 rounded-lg border border-zinc-200 px-3 py-2 last:mb-0 hover:bg-zinc-50">
    <input
        type="checkbox"
        name="{{ name }}"
        value="{{ value }}"
        {%- if checked %} checked{% endif %}
        class="mt-0.5 size-4 accent-accent"
    >
    <span>
        <span class="block text-sm font-medium text-zinc-800">{{ label }}</span>
        {% if description %}
            <span class="block text-xs text-zinc-500">{{ description }}</span>
        {% endif %}
    </span>
</label>
