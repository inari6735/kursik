{% props href, active = false %}

<a href="{{ href }}" class="{{ active
    ? 'rounded-lg bg-accent-soft px-3 py-2 text-base font-semibold text-secondary'
    : 'rounded-lg px-3 py-2 text-base font-semibold text-zinc-600 hover:bg-zinc-50 hover:text-ink' }}">
    {%- block content %}{% endblock -%}
</a>
