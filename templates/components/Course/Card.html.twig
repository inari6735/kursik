{# Clickable course tile for the course list. `course` = CourseListItem DTO. #}
{% props course %}

<a href="{{ path('course_show', {id: course.id}) }}"
   class="block rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm transition hover:border-primary/60 hover:shadow-md">
    <div class="mb-3 flex items-start justify-between gap-3">
        <h2 class="min-w-0 truncate text-h5 text-ink">{{ course.title }}</h2>
        <twig:Badge variant="{{ course.status }}">{{ course.status }}</twig:Badge>
    </div>
    <p class="text-xs text-zinc-500">Created {{ course.createdAt|date('Y-m-d H:i') }}</p>
</a>
