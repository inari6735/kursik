{% props title, message = null %}

{% set actions %}{% block content %}{% endblock %}{% endset %}

<div class="rounded-2xl border border-dashed border-primary/60 bg-white px-6 py-16 text-center">
    <h2 class="text-h4 text-ink">{{ title }}</h2>
    {% if message %}
        <p class="mt-2 text-sm text-zinc-500">{{ message }}</p>
    {% endif %}
    {% if actions|trim is not empty %}
        <div class="mt-6 flex justify-center">{{ actions }}</div>
    {% endif %}
</div>
