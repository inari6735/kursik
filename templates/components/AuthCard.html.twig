{# Narrow centered card for login/registration; `footer` block = cross-link line.
   Owns its card container: an outlet block nested in another component's children
   would collide with the compiler-generated content block. #}
{% props title, error = null %}

<div class="w-full rounded-2xl border border-primary/50 bg-white p-8 shadow-lg shadow-primary/25">
    {# Card-scale heading: h1 element for semantics, H3 size for the narrow card. #}
    <h1 class="mb-6 text-center text-h3 text-secondary">{{ title }}</h1>

    {% if error %}
        <div class="mb-4">
            <twig:Alert type="error">{{ error }}</twig:Alert>
        </div>
    {% endif %}

    {% block content %}{% endblock %}

    {% if block('footer') is defined %}
        <p class="mt-6 text-center text-sm text-zinc-500">{% block footer %}{% endblock %}</p>
    {% endif %}
</div>
