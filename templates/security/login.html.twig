{% extends 'base.html.twig' %}

{% block title %}Log in — kursik{% endblock %}

{% block body %}
    <twig:AuthCard title="Log in" error="{{ error ? error.messageKey|trans(error.messageData, 'security') : null }}">
        <form action="{{ path('app_login') }}" method="post">
            <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">
            <input type="hidden" name="_target_path" value="{{ app.request.query.get('redirect', '') }}">

            <twig:Field label="Email" name="_username" type="email" value="{{ last_email }}" required autofocus autocomplete="email" />
            <twig:Field label="Password" name="_password" type="password" required autocomplete="current-password" />

            <twig:Button fullWidth>Log in</twig:Button>
        </form>

        <twig:block name="footer">
            No account yet? <twig:Link href="{{ path('app_register') }}">Register</twig:Link>
        </twig:block>
    </twig:AuthCard>
{% endblock %}
