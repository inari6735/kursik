{% extends 'base.html.twig' %}

{% block title %}Log in{% endblock %}

{% block body %}
    {% include 'course/_flashes.html.twig' %}

    <h1>Log in</h1>

    {% if error %}
        <div class="flash flash-error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
    {% endif %}

    <form action="{{ path('app_login') }}" method="post">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
        <input type="hidden" name="_target_path" value="{{ app.request.query.get('redirect', '') }}">

        <div>
            <label for="login-email">Email</label>
            <input type="email" id="login-email" name="_username" value="{{ last_email }}" required autofocus>
        </div>
        <div>
            <label for="login-password">Password</label>
            <input type="password" id="login-password" name="_password" required>
        </div>

        <button type="submit">Log in</button>
    </form>

    <p>No account yet? <a href="{{ path('app_register') }}">Register</a></p>
{% endblock %}