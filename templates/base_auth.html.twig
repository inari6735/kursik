{% extends 'base.html.twig' %}

{# Chrome-free layout for login/registration: two columns — the graphic on the
   left, the auth card on the right. The graphic hides on small screens. #}
{% block layout %}
    <div class="flex min-h-screen items-center justify-center px-4 py-8">
        <div class="flex w-full max-w-4xl items-center justify-center gap-12">
            <img src="{{ asset('images/login_logo.png') }}" alt="" class="hidden min-w-0 max-w-md flex-1 md:block">

            <div class="w-full max-w-sm md:shrink-0">
                <twig:Layout:Flashes />
                {% block body %}{% endblock %}
            </div>
        </div>
    </div>
{% endblock %}
